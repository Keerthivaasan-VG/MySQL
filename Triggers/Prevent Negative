DELIMITER $$

CREATE TRIGGER prevent_negative_price
BEFORE UPDATE ON PRODUCTS
FOR EACH ROW
BEGIN
    -- Check if the new price being entered is less than 0
    IF NEW.PRICE < 0 THEN
        -- Stop the update and show an error message
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Price cannot be negative';
    END IF;
END $$

DELIMITER ;
