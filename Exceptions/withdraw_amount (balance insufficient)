DELIMITER $$

CREATE PROCEDURE withdraw_amount(
    IN p_account_no INT, 
    IN p_amount INT
)
BEGIN
    
    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
        SELECT 'Error: Error occurred during transaction.' AS Status;
    END;

    DECLARE EXIT HANDLER FOR SQLSTATE '45000'
    BEGIN
        SELECT 'Error: Insufficient balance.' AS Status;
    END;

    IF (SELECT BALANCE FROM accounts WHERE ACCOUNT_NO = p_account_no) < p_amount THEN
        SIGNAL SQLSTATE '45000';
    END IF;

    UPDATE accounts 
    SET BALANCE = BALANCE - p_amount 
    WHERE ACCOUNT_NO = p_account_no;

    INSERT INTO transactions(ACCOUNT_NO, TRANS_TYPE, AMOUNT, TRANS_DATE)
    VALUES(p_account_no, 'Debit', p_amount, CURDATE());

    SELECT 'Withdrawal successful.' AS Status;
END$$

DELIMITER ;
